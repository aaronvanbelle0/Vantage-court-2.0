export function faqSchema() {
  return {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: FAQS.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: f.a,
      },
    })),
  };
}

// ------------------------------------------------------------
// Service schemas (one per service)
// ------------------------------------------------------------
export function serviceSchemas() {
  return SERVICES.map((s) => ({
    "@context": "https://schema.org",
    "@type": "Service",
    name: s.name,
    description: s.description,
    provider: { "@id": `${BUSINESS.url}/#business` },
    areaServed: BUSINESS.serviceArea.map((county) => ({
      "@type": "AdministrativeArea",
      name: `${county}, Washington`,
    })),
    serviceType: s.shortName,
  }));
}

// ------------------------------------------------------------
// Helper: render array of schemas as one combined script payload
// ------------------------------------------------------------
export function combinedSchema(schemas: object[]) {
  return {
    "@context": "https://schema.org",
    "@graph": schemas.map((s) => {
      // Strip nested @context from individual graph entries
      const { ["@context"]: _, ...rest } = s as Record<string, unknown>;
      return rest;
    }),
  };
}
