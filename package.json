// ============================================================
// JSON-LD STRUCTURED DATA GENERATORS
// These produce Schema.org markup that gets rendered server-side
// for Google, Bing, and rich result eligibility.
// ============================================================

import { BUSINESS, SERVICES } from "./business";

// ------------------------------------------------------------
// LocalBusiness — the core local SEO signal.
// Uses SportsActivityLocation as the more specific subtype.
// ------------------------------------------------------------
export function localBusinessSchema() {
  return {
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "GeneralContractor"],
    "@id": `${BUSINESS.url}/#business`,
    name: BUSINESS.name,
    legalName: BUSINESS.legalName,
    description: BUSINESS.description,
    url: BUSINESS.url,
    telephone: BUSINESS.phone,
    email: BUSINESS.email,
    image: `${BUSINESS.url}${BUSINESS.ogImagePath}`,
    logo: `${BUSINESS.url}${BUSINESS.logoPath}`,
    priceRange: BUSINESS.priceRange,
    foundingDate: BUSINESS.founded,
    address: {
      "@type": "PostalAddress",
      streetAddress: BUSINESS.address.street,
      addressLocality: BUSINESS.address.city,
      addressRegion: BUSINESS.address.region,
      postalCode: BUSINESS.address.postalCode,
      addressCountry: BUSINESS.address.country,
    },
    geo: {
      "@type": "GeoCoordinates",
      latitude: BUSINESS.geo.latitude,
      longitude: BUSINESS.geo.longitude,
    },
    areaServed: BUSINESS.serviceArea.map((county) => ({
      "@type": "AdministrativeArea",
      name: `${county}, Washington`,
    })),
    openingHoursSpecification: BUSINESS.hours.map((h) => ({
      "@type": "OpeningHoursSpecification",
      dayOfWeek: h.days,
      opens: h.open,
      closes: h.close,
    })),
    sameAs: BUSINESS.sameAs,
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Court Construction & Resurfacing Services",
      itemListElement: SERVICES.map((s) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: s.name,
          description: s.description,
        },
      })),
    },
  };
}

// ------------------------------------------------------------
// Website schema — declares site identity + search behavior
// ------------------------------------------------------------
export function websiteSchema() {
  return {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${BUSINESS.url}/#website`,
    url: BUSINESS.url,
    name: BUSINESS.name,
    description: BUSINESS.description,
    publisher: { "@id": `${BUSINESS.url}/#business` },
    inLanguage: "en-US",
  };
}

// ------------------------------------------------------------
// Breadcrumb schema — for hierarchical navigation
// ------------------------------------------------------------
export function breadcrumbSchema(
  items: { name: string; url: string }[]
) {
  return {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: items.map((item, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: item.name,
      item: item.url,
    })),
  };
}

// ------------------------------------------------------------
// FAQ schema — eligible for FAQ rich results in SERP
