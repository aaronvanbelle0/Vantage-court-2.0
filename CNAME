import type { MetadataRoute } from "next";
import { BUSINESS, SERVICES } from "@/lib/business";

export default function sitemap(): MetadataRoute.Sitemap {
  const now = new Date();

  // Homepage
  const routes: MetadataRoute.Sitemap = [
    {
      url: BUSINESS.url,
      lastModified: now,
      changeFrequency: "weekly",
      priority: 1.0,
    },
  ];

  // Service pages (when you build them, files go in app/services/[slug]/page.tsx)
  // Keep these uncommented even before pages exist — they signal intended structure.
  // Comment them out if you want a strictly-current sitemap.
  /*
  SERVICES.forEach((s) => {
    routes.push({
      url: `${BUSINESS.url}/services/${s.slug}`,
      lastModified: now,
      changeFrequency: "monthly",
      priority: 0.8,
    });
  });

  // Location pages
  BUSINESS.citiesServed.forEach((city) => {
    routes.push({
      url: `${BUSINESS.url}/locations/${city.name.toLowerCase().replace(/\s+/g, "-")}-wa`,
      lastModified: now,
      changeFrequency: "monthly",
      priority: 0.7,
    });
  });
  */

  return routes;
}
